{
  "name": "@EIT-Digital-Alumni/eit-icons",
  "version": "1.0.0",
  "description": "A web component for displaying EIT icons.",
  "type": "module",
  "main": "dist/eit-icons.cjs.js",
  "module": "dist/eit-icons.esm.js",
  "browser": "dist/eit-icons.umd.js",
  "unpkg": "dist/eit-icons.umd.js",
  "exports": {
    ".": {
      "import": "./dist/eit-icons.esm.js",
      "require": "./dist/eit-icons.cjs.js",
      "browser": "./dist/eit-icons.umd.js"
    },
    "./style": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "icons",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "start": "cd example && npm run dev",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "@EIT-Digital-Alumni:registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EIT-Digital-Alumni/eit-icons.git"
  },
  "keywords": [
    "webcomponent",
    "icons",
    "svg",
    "eit"
  ],
  "license": "proprietary",
  "bugs": {
    "url": "https://github.com/EIT-Digital-Alumni/eit-icons/issues"
  },
  "homepage": "https://github.com/EIT-Digital-Alumni/eit-icons#readme",
  "devDependencies": {
    "rollup": "^4.13.0"
  }
}
